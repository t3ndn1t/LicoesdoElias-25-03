using System;

class Votos
{
    static void Main()
    {
        Console.Write("Total de eleitores: ");
        double total = double.Parse(Console.ReadLine());
        Console.Write("Votos brancos: ");
        double brancos = double.Parse(Console.ReadLine());
        Console.Write("Votos nulos: ");
        double nulos = double.Parse(Console.ReadLine());
        Console.Write("Votos válidos: ");
        double validos = double.Parse(Console.ReadLine());

        Console.WriteLine($"Brancos: {brancos / total * 100:F2}%");
        Console.WriteLine($"Nulos:   {nulos / total * 100:F2}%");
        Console.WriteLine($"Válidos: {validos / total * 100:F2}%");
    }
}
